# Harbourview — Environment Variables
# Copy to .env.local for local development.
# Add all keys in Vercel: Project Settings > Environment Variables.

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
HARBOURVIEW_TO_EMAIL=team@yourdomain.com
HARBOURVIEW_FROM_EMAIL=noreply@harbourview.io

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://harbourview.vercel.app
NEXT_PUBLIC_BOOKING_URL=

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET=
