# Harbourview — Environment Variables
# Copy to .env.local for local development.
# Add all keys in Vercel: Project Settings > Environment Variables.

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
HARBOURVIEW_TO_EMAIL=harborviewcompany@gmail.com,tylercampbell5@outlook.com
HARBOURVIEW_FROM_EMAIL=noreply@harbourview.io

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://harbourview.vercel.app
NEXT_PUBLIC_BOOKING_URL=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Locked canonical project URL. Do not replace with another Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://zvxdgkukjrrwamdpqrg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin ────────────────────────────────────────────────────────────────────
# Protects /admin/* routes and API routes.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Uncomment and configure your provider
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=harbourview.vercel.app
# NEXT_PUBLIC_POSTHOG_KEY=
